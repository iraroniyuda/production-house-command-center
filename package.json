{
  "name": "production-house-command-center",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24.16.0 <25",
    "pnpm": "11.15.1"
  },
  "scripts": {
    "web:dev": "pnpm --filter web dev",
    "web:lint": "pnpm --filter web lint",
    "web:typecheck": "pnpm --filter web exec tsc --noEmit",
    "web:build": "pnpm --filter web build",
    "infra:config": "docker compose --env-file infra/.env -f infra/compose.yaml config",
    "infra:pull": "docker compose --env-file infra/.env -f infra/compose.yaml pull",
    "infra:up": "docker compose --env-file infra/.env -f infra/compose.yaml up -d",
    "infra:down": "docker compose --env-file infra/.env -f infra/compose.yaml down",
    "infra:ps": "docker compose --env-file infra/.env -f infra/compose.yaml ps",
    "infra:logs": "docker compose --env-file infra/.env -f infra/compose.yaml logs -f",
    "infra:logs:tail": "docker compose --env-file infra/.env -f infra/compose.yaml logs --tail 200"
  }
}
