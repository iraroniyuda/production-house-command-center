# Auto-detect text files
* text=auto

# Repository text files use LF
*.md         text eol=lf
*.txt        text eol=lf
*.json       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.xml        text eol=lf
*.java       text eol=lf
*.kt         text eol=lf
*.kts        text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.sql        text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.css        text eol=lf
*.scss       text eol=lf
*.html       text eol=lf
*.sh         text eol=lf

# Native Windows scripts use CRLF
*.ps1        text eol=crlf
*.bat        text eol=crlf
*.cmd        text eol=crlf

# Binary files
*.docx       binary
*.pdf        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.webp       binary
*.ico        binary
*.zip        binary
